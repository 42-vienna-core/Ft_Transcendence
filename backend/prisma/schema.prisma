// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output = "../prisma/generated"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Users {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String @map("password_hash")
  name     String
  role     Role   @default(PLAYER)
  isBot		Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  //isVerified Boolean @default(false) @map("is_verified")
  //isBlocked  Boolean @default(false) @map("is_blocked")

  sessions Sessions[]
	gameParticipants	GameParticipants[]
	gamesWon			GameResults[] @relation("Winner")

  avatar String?

  gameRoom		GameRoom []
  roomUser		RoomUser []

  sentRequests  FriendsRequest [] @relation("SentRequests")
  receivedRequests  FriendsRequest [] @relation("ReceivedRequests")
}

enum Role {
  PLAYER
  ADMIN
  BOT
}

model Sessions {
  id String @id @default(uuid()) @db.Uuid

  userId Int  @map("user_id")
  user   Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String @unique @map("refresh_token_hash")

  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  revokedAt DateTime? @map("revoked_at")

  userAgent String? @map("user_agent")
  ip        String? @map("ip")

  @@index([userId])
}

model GameRoom {
	id			    String @id @default(uuid())
	name		    String
	maxUsers	  Int @default(4)
	ownerId		  Int?
	createdAt	  DateTime @default(now())
	updatedAt	  DateTime @updatedAt
	
  status      RoomStatus @default(WAITING)
	type		    RoomType @default(PUBLIC)
	roomUsers		RoomUser[]
	gameResults		GameResults[]
	owner		    Users? @relation(fields: [ownerId], references: [id])
}

model RoomUser {

  id        String  @id @default(uuid())
  roomId    String
  userId    Int
  socketId  String?

  room      GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])

}

enum RoomType {
  PUBLIC
  PRIVATE
}

model FriendsRequest {
  id     String @id @default(uuid())

  senderId      Int
  sender        Users @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId    Int
  receiver      Users @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  status  RequestStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([senderId, receiverId])
}

model GameResults{
	id				String @id @default(uuid())
	
	roomId			String
	room			GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
	
	winnerId		Int?
	winner			Users? @relation("Winner",fields: [winnerId], references:[id])
	
	participants	GameParticipants[]
	ticks			Int
	createdAt		DateTime @default(now())
	updatedAt		DateTime @updatedAt


}

model GameParticipants{
	id				String @id @default(uuid())

	gameId			String
	game			GameResults @relation(fields:[gameId], references:[id], onDelete: Cascade)
	
	userId			Int
	user			Users @relation(fields:[userId], references: [id], onDelete: Cascade)
	alive			Boolean

	score			Int

	@@unique([gameId, userId])
}


enum RequestStatus {
  ACCEPTED
  PENDING
  REJECTED
}

enum RoomStatus {
  WAITING
  READY
  PLAYING
  FINISHED
}