generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id                              Int        @id @default(autoincrement())
  Email                           String     @unique
  Password                        String
  Username                        String
  role                            Role       @default(PLAYER)
  resetCode                       String?
  codeExpire                      DateTime?
  createdAt                       DateTime   @default(now())
  updatedAt                       DateTime   @updatedAt
  Friends_Friends_friendIdToUsers Friends[]  @relation("Friends_friendIdToUsers")
  Friends_Friends_userIdToUsers   Friends[]  @relation("Friends_userIdToUsers")
  gameRooms                       GameRoom[]
  messages                        Message[]
  roomsUsers                      RoomUser[]
  sessions                        Sessions[]
  history                         UserStats?
}

model UserStats {
  id          Int      @id @default(autoincrement())

  Email       String   @unique
  user        Users    @relation(fields: [Email], references: [Email], onDelete: Cascade)
  gamesWon    Int      @default(0)
  gamesLost   Int      @default(0)

  totalScore  Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RoomUser {

  id       String   @id @default(uuid())
  roomId   String
  socketId String?
  userId   Int
  room     GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     Users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model GameRoom {
  id            String     @id @default(uuid())
  name          String     @default("Room")
  maxUsers      Int        @default(4)
  ownerId       Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  type          RoomType   @default(PUBLIC)
  status        RoomStatus @default(WAITING)
  users         Users?     @relation(fields: [ownerId], references: [id])
  messages      Message   []
  roomUsers     RoomUser  []
}

model Sessions {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              Int
  refreshTokenHash    String    @unique
  expiresAt           DateTime
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  revokedAt           DateTime?
  users               Users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  roomId    String
  createdAt DateTime @default(now())
  userId    Int
  room      GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      Users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friends {
  id                            String      @id @default(uuid())
  userId                        Int
  friendId                      Int
  status                        FriendStatus @default(PENDING)
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime
  usersFriendsFriendIdToUsers   Users        @relation("Friends_friendIdToUsers", fields: [friendId], references: [id])
  usersFriendsUserIdToUsers     Users        @relation("Friends_userIdToUsers", fields: [userId], references: [id])

  @@unique([userId, friendId])
}
enum Role {
  PLAYER
  ADMIN
}

enum RoomType {
  PUBLIC
  PRIVATE
}

enum FriendStatus {
  PENDING
  ACCEPTED
  BLOCKED
  REJECTED
}

enum RoomStatus {
  WAITING
  PLAYING
  FINISHED
}